# Copy this file to .env before deploying. Never commit the generated .env file.
APP_PORT=80

MYSQL_DATABASE=ai_interview
MYSQL_ROOT_PASSWORD=replace-with-a-long-random-root-password
MYSQL_APP_USER=ai_interview_app
MYSQL_APP_PASSWORD=replace-with-a-long-random-application-password

REDIS_PASSWORD=replace-with-a-long-random-redis-password
# At least 32 characters. Generate a unique random value for every environment.
JWT_SECRET=replace-with-a-random-jwt-secret-at-least-32-characters

DEEPSEEK_ENABLED=true
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
